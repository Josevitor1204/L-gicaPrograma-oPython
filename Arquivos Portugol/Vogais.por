programa {
  funcao inicio() {
    cadeia vogal1, vogal2, vogal3, vogal4, vogal5
    escreva("Escreva a primeira vogal: ")
    leia(vogal1)
    escreva("Escreva a segunda vogal: ")
    leia(vogal2)
    escreva("Escreva a terceira vogal: ")
    leia(vogal3)
    escreva("Escreva a quarta vogal: ")
    leia(vogal4)
    escreva("Escreva a quinta vogal: ")
    leia(vogal5)
    escreva("As vogais em ordem inversa é: ",vogal5,", ",vogal4,", ",vogal3,", ",vogal2,", ",vogal1)
  }
}
