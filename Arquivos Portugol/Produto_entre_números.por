programa {
  funcao inicio() {
  
  inteiro num1, num2, num3, num4

  escreva("Digite o primeiro número: ")
  leia(num1)
  escreva("Digite o segundo número: ")
  leia(num2)
  escreva("Digite o terceiro número: ")
  leia(num3)
  escreva("Digite o quarto número: ")
  leia(num4)

  real multi
  multi = num1*num2*num3*num4

  escreva("Os números digitados foram: ", num1,", ", num2,", ", num3,", ", num4)
  escreva("\n O produto entre esses números é: ", multi)
  }
}
